<!--pages/result/result.wxml-->
<view class="container">
  <view class="result-card">
    <view class="icon">🎉</view>
    <text class="title">考试完成</text>

    <view class="score-display">
      <text class="score-value">{{score}}</text>
      <text class="score-label-text">分</text>
    </view>

    <!-- 工资提升提示 -->
    <view wx:if="{{score >= 96}}" class="salary-tip salary-high">
      <text class="salary-tip-text">🎉 恭喜您工资提升500元！</text>
    </view>
    <view wx:elif="{{score >= 90}}" class="salary-tip salary-medium">
      <text class="salary-tip-text">🎊 恭喜您工资提升200元！</text>
    </view>
    <view wx:elif="{{score >= 80}}" class="salary-tip salary-low">
      <text class="salary-tip-text">🎯 恭喜您工资提升100元！</text>
    </view>

    <view class="info-row">
      <text class="info-label">考生姓名：</text>
      <text class="info-value">{{name}}</text>
    </view>

    <view class="info-row">
      <text class="info-label">考试岗位：</text>
      <text class="info-value">{{roleName}}</text>
    </view>

    <view class="info-row">
      <text class="info-label">考试用时：</text>
      <text class="info-value">{{duration}}</text>
    </view>

    <view class="info-row">
      <text class="info-label">题目数量：</text>
      <text class="info-value">45题</text>
    </view>

    <view class="btn" bindtap="backToHome">返回首页</view>
    <view class="btn btn-outline" bindtap="viewAdmin">查看记录</view>
  </view>

  <view class="footer">
    <text class="footer-text">客观题自动评分，满分100分</text>
  </view>
</view>
