/* pages/exam/exam.wxss */
.exam-header {
  background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
  color: #fff;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-left {
  flex: 1;
}

.role-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.user-name {
  display: block;
  font-size: 24rpx;
  opacity: 0.9;
}

.header-right {
  text-align: center;
}

.timer {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  font-family: 'Courier New', monospace;
}

.timer-label {
  display: block;
  font-size: 20rpx;
  opacity: 0.8;
}

.question-list {
  height: calc(100vh - 240rpx);
  padding: 30rpx;
}

.question-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  border-left: 6rpx solid #1e3c72;
}

.question-card.submitted {
  border-left-color: #999;
}

.question-type {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.score {
  font-size: 24rpx;
  color: #999;
}

.question-content {
  margin-bottom: 30rpx;
}

.question-text {
  font-size: 30rpx;
  line-height: 1.6;
  color: #333;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option {
  background: #f8f9fa;
  padding: 24rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  transition: all 0.3s;
}

.option.selected {
  background: #e3f2fd;
  border: 2rpx solid #1e3c72;
}

.option-checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #fff;
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #1e3c72;
}

.option.selected .option-checkbox {
  background: #1e3c72;
  color: #fff;
  border-color: #1e3c72;
}

.option-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #666;
  min-width: 40rpx;
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.fill-inputs {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.fill-input-wrapper {
  background: #f8f9fa;
  padding: 20rpx;
  border-radius: 12rpx;
}

.fill-input {
  width: 100%;
  padding: 16rpx;
  background: #fff;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.subjective-input {
  background: #f8f9fa;
  padding: 20rpx;
  border-radius: 12rpx;
}

.textarea {
  width: 100%;
  min-height: 300rpx;
  padding: 20rpx;
  background: #fff;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.answer-box {
  background: #fff3cd;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-top: 24rpx;
  border-left: 4rpx solid #ffc107;
}

.answer-label {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.answer-value {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  white-space: pre-wrap;
}

.answer-correct {
  display: block;
  font-size: 26rpx;
  color: #2e7d32;
  margin-bottom: 12rpx;
}

.answer-explanation {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 24rpx 30rpx;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.bottom-bar .btn {
  flex: 1;
}
