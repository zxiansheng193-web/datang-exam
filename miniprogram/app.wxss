/* app.wxss */
page {
  background-color: #f5f5f5;
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  padding: 30rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #1e3c72;
}

.btn {
  background: #1e3c72;
  color: #fff;
  border-radius: 50rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  text-align: center;
  margin-top: 20rpx;
}

.btn:active {
  opacity: 0.8;
}

.btn-outline {
  background: #fff;
  color: #1e3c72;
  border: 2rpx solid #1e3c72;
}

.input {
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  background: #fff;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
}

.badge {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  background: #e8f0fe;
  color: #1e3c72;
}

.badge-success {
  background: #e8f5e9;
  color: #2e7d32;
}

.badge-warning {
  background: #fff3e0;
  color: #e65100;
}

.badge-danger {
  background: #ffebee;
  color: #c62828;
}

.stat-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  padding: 40rpx 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  margin-top: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.9;
}
